# Frontend Environment Variables (Vite)
# Copy this to .env and fill in your own values
# Note: Only variables prefixed with VITE_ are exposed to browser

# OpenWeather API Key (Required)
# Get your free key from: https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_api_key_here

# Backend API URL (Optional, defaults to localhost)
VITE_BACKEND_URL=http://127.0.0.1:8000
